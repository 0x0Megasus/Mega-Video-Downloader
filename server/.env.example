# Server port (default: 5000 for single process, 3000 for cluster)
PORT=5000

# Telegram API credentials (required)
# Get these from https://my.telegram.org/apps
API_ID=your_api_id
API_HASH=your_api_hash

# Telegram StringSession (persisted auth session)
# Generate via: https://my.telegram.org or using the `input` login script
SESSION=your_telegram_string_session

# Telegram bot username that processes download requests
# The bot receives URLs and sends back media files
BOT_USERNAME=@YourBotUsername

# Allowed CORS origins (comma-separated for multiple)
# Example: https://example.com,https://app.example.com
CLIENT_URL=http://localhost:5173

# Cluster worker count (default: 1)
# WARNING: >1 shares the same Telegram session and may cause AUTH_KEY_DUPLICATED
# Set to 1 unless you have per-worker sessions configured
WORKER_COUNT=1

# Initial Telegram connection delay in ms (default: 20000)
# Helps Railway-like deployments wait for old container to fully stop
FIRST_CONNECT_DELAY=20000
